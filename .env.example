# =============================================================================
# Sanad production environment variables.
# Copy to .env and fill in real values before running docker compose.
#
#   cp .env.example .env
#   nano .env
#   docker compose -f docker-compose.prod.yml up -d
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password
DB_NAME=sanad
DB_USERNAME=sanad_app
DB_PASSWORD=CHANGE_ME_strong_app_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_hex_chars

# ── Yemen ID backend ─────────────────────────────────────────────────────────
YEMEN_ID_BASE_URL=https://sample.com/base_path
YEMEN_ID_BEARER_TOKEN=CHANGE_ME_provider_token

# ── Bootstrap admin (first deploy only — delete after) ────────────────────────
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@promatrix.ai
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_admin_password
