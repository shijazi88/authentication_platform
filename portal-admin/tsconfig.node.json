{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "composite": true,
    "outDir": "./node_modules/.cache/tsconfig-node",
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig-node/tsconfig.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["vite.config.ts"]
}
